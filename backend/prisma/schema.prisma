  unitPrice   Float    @default(0)
  currency    String   @default("MZN")
  taxRate     Float    @default(0) // percentagem, ex: 16 = 16%
  unit        String? // ex: "hora", "unidade", "mes"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  quoteItems QuoteItem[]
  files      File[]

  @@index([workspaceId])
  @@map("products")
}

model Quote {
  id            String      @id @default(cuid())
  number        String // ex: PROP-2026-0001
  title         String
  status        QuoteStatus @default(DRAFT)
  currency      String      @default("MZN")
  notes         String? // termos e condicoes / observacoes
  discountType  String      @default("none") // none | percent | amount
  discountValue Float       @default(0)
  taxRate       Float       @default(0) // imposto global % (fallback se a linha nao tiver)
  validUntil    DateTime?
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId   String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  items QuoteItem[]

  @@index([workspaceId])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model QuoteItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  taxRate     Float  @default(0) // % por linha
  position    Int    @default(0)

  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  @@index([quoteId])
  @@map("quote_items")
}

// ==================== IA VENDEDORA: SUGESTOES ====================
//
// Cada vez que a IA Vendedora analisa uma conversa, produz uma sugestao
// estruturada (uma ou mais partes de texto, possivelmente com produto
// anexado, ou pedido de handoff). Em modo supervisionado fica PENDING ate
// o humano aprovar/editar/descartar. Em modo auto (Fase 4) e enviada
// directamente e nasce ja como SENT.
//
// Persistir cada sugestao serve para tres coisas:
//   1. UI da Caixa de Entrada mostrar "tem sugestao pendente"
//   2. Auditoria: ver o que a IA quis dizer, mesmo que tenha sido editada
//   3. Aprendizagem futura: a Fase 4 vai cruzar correccoes humanas com
//      sugestoes originais para alimentar aiLearnedMemory
//
model AiSalesSuggestion {
  id               String    @id @default(cuid())
  // === Origem ===
  workspaceId      String
  contactId        String
  leadId           String?
  // Mensagem inbound que disparou a sugestao (null se foi gerada manualmente)
  triggerMessageId String?
  // === Conteudo proposto pela IA ===
  // Array de strings com as partes da resposta fragmentada (max 4 por config).
  parts            Json
  // Accao que a IA escolheu:
  //   send_text      -> envia so o texto em parts
  //   send_product   -> envia texto + anexa ficheiros do produto
  //   handoff        -> passa para humano (parts pode ser mensagem de transicao)
  //   wait           -> nao responde agora (ex: lead pediu para falar so amanha)
  action           String    @default("send_text")
  // Se action=send_product, qual produto e que ficheiros enviar.
  productId        String?
  productFileIds   Json      @default("[]")
  // Justificativa interna: porque escolheu esta resposta (debug + auditoria).
  reasoning        String?   @db.Text
  // Chaves dos principios que a IA usou (string[]). Util para o painel.
  principlesUsed   Json      @default("[]")
  // Modelo e tokens usados (para custos/diagnostico).
  modelUsed        String?
  promptTokens     Int?
  completionTokens Int?
  // === Estado e decisao humana ===
  // PENDING   -> a aguardar revisao humana
  // APPROVED  -> enviada como esta (parts originais)
  // EDITED    -> humano editou e enviou (finalParts != parts)
  // DISCARDED -> humano rejeitou, nao enviou nada
  // SENT      -> modo auto, enviada sem revisao
  // FAILED    -> erro ao enviar
  status           String    @default("PENDING")
  // Se editada, as partes finais que foram efectivamente enviadas.
  finalParts       Json?
  // IDs das mensagens criadas ao enviar (string[], correspondem a Message.id).
  sentMessageIds   Json      @default("[]")
  decidedAt        DateTime?
  decidedById      String?
  errorDetail      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact        Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  triggerMessage Message?  @relation("AiSuggestionTriggerMessage", fields: [triggerMessageId], references: [id], onDelete: SetNull)
  decidedBy      User?     @relation("AiSuggestionDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([contactId, createdAt])
  @@index([leadId, createdAt])
  @@map("ai_sales_suggestions")
}

// ==================== IA VENDEDORA: TREINADOR CONVERSACIONAL ====================
//
// Regras de coaching que o admin ensina a IA atraves de conversa ou que sao
// geradas automaticamente pelo job nocturno a partir de conversas reais com
// sinal positivo (lead avancou de etapa, fechou negocio, etc).
//
// Sao injectadas no system prompt da IA Vendedora, ordenadas por prioridade
// e filtradas por palavras-chave da mensagem do lead quando o conjunto activo
// e grande.
model AiCoachingRule {
  id                 String   @id @default(cuid())
  workspaceId        String

  // Situacao em que a regra se aplica (ex: "lead pergunta o preco antes de ver o produto")
  situation          String   @db.Text
  // Accao/resposta recomendada para a IA seguir nesse caso
  recommendedAction  String   @db.Text
  // Exemplos opcionais (array JSON: [{ leadMessage, aiResponse }])
  examples           Json     @default("[]")
  // Tom especifico para esta regra (ex: "mais empatico", "mais directo"). Opcional.
  tone               String?
  // Categoria livre para agrupamento (ex: "preco", "objeccao", "boas-vindas")
  category           String?
  // Palavras-chave (lowercase) para filtro rapido por relevancia
  keywords           String[] @default([])

  // Origem da regra:
  //   coach_chat    -> ensinada pelo admin via chat com o coach
  //   auto_learned  -> gerada pelo job nocturno a partir de conversas reais
  //   manual        -> criada directamente no painel
  source             String   @default("coach_chat")
  // Confianca (0-1). 1.0 para regras ensinadas, < 1.0 para auto-aprendidas.
  confidence         Float    @default(1.0)
  // Se a regra esta activa no prompt da IA
  isActive           Boolean  @default(true)
  // Prioridade: regras com prioridade mais alta sao incluidas primeiro
  priority           Int      @default(0)

  // Contadores de uso para o painel
  timesApplied       Int      @default(0)
  lastAppliedAt      DateTime?
  // IDs de conversas/mensagens das quais a regra foi derivada (auto-learning)
  derivedFromConvIds String[] @default([])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdById        String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive, priority])
  @@index([workspaceId, source])
  @@map("ai_coaching_rules")
}

// Log de consumo de tokens LLM por workspace, agnostico do feature/provider.
// Uma linha por chamada bem-sucedida ao Groq/Gemini. Usado para mostrar
// barras de quota na UI e para aplicar limites por plano.
model AiUsageLog {
  id               String   @id @default(cuid())
  workspaceId      String
  provider         String   // 'groq' | 'gemini'
  model            String
  feature          String   // 'sales' | 'coach' | 'chatbot' | 'copilot' | 'learning' | 'autolearn'
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, feature, createdAt])
  @@map("ai_usage_logs")
}

// Limites de tokens por plano (STARTER, GROWTH, BUSINESS, ENTERPRISE).
// Configuravel via UI admin. Um registo por plano. Se um plano nao tiver
// linha, assume os defaults definidos em lib/plans.ts.
model PlanAiLimit {
  id                  String   @id @default(cuid())
  planKey             String   @unique  // STARTER | GROWTH | BUSINESS | ENTERPRISE
  dailyTokenLimit     Int      // -1 = ilimitado
  monthlyTokenLimit   Int      // -1 = ilimitado
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@map("plan_ai_limits")
}

// Histórico das conversas do admin com o coach (meta-IA que ajuda a treinar
// a IA Vendedora). Cada documento e uma sessao com array de mensagens.
model AiCoachConversation {
  id             String   @id @default(cuid())
  workspaceId    String
  // Titulo curto gerado da primeira mensagem
  title          String?
  // Array JSON de mensagens: [{ role: "user"|"assistant"|"system", content: string, createdAt: string, rulesCreated?: string[] }]
  messages       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, updatedAt])
  @@map("ai_coach_conversations")
}

// Marcacoes (Fase 3 da reconfiguracao): consultas, reunioes, atendimentos
// agendados. Diferentes de Tasks porque tem hora de inicio + duracao +
// estado com semantica de agendamento (CONFIRMADA, REALIZADA, FALTOU).
// Um Appointment pertence sempre a um Contact e (opcionalmente) a um Lead.
model Appointment {
  id            String            @id @default(cuid())
  workspaceId   String
  contactId     String
  leadId        String?
  assignedToId  String?
  // Ex: "Consulta de rotina", "Reuniao de proposta", "Sessao de fisioterapia"
  title         String
  description   String?
  // Localizacao/sala/link de videochamada. Texto livre.
  location      String?
  // Data e hora de inicio (armazenada em UTC).
  startsAt      DateTime
  // Duracao em minutos. Default 30.
  durationMin   Int               @default(30)
  status        AppointmentStatus @default(SCHEDULED)
  // Marca se ja foi enviado o lembrete via WhatsApp (para nao duplicar)
  reminderSentAt DateTime?
  // Notas apos a marcacao (relato, receita, proximos passos)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   String?

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("appointmentAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([workspaceId, startsAt])
  @@index([contactId, startsAt])
  @@index([assignedToId, startsAt])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED   // agendada, ainda por confirmar
  CONFIRMED   // cliente confirmou
  COMPLETED   // aconteceu
  CANCELED    // cancelada por qualquer lado antes da hora
  NO_SHOW     // cliente nao apareceu
}
