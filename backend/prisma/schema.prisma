generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  avatar           String?
  phone            String?
  // JID do grupo WhatsApp para onde se envia o digest diário deste utilizador
  // (formato: 258...-12345@g.us). Se preenchido, sobrepõe-se ao `phone` no digest.
  digestGroupJid   String?
  role             UserRole  @default(AGENT)
  isActive         Boolean   @default(true)
  status           String    @default("OFFLINE") // ONLINE | AWAY | BUSY | DND | OFFLINE
  internalNotes    String?
  viewOnlyOwn      Boolean   @default(false)
  lastLoginAt      DateTime?
  // 2FA
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  // Preferencias notificacoes (JSON: { newLead, taskOverdue, newMessage, mention } )
  emailPreferences Json      @default("{\"newLead\":true,\"taskOverdue\":true,\"newMessage\":false,\"mention\":true}")
  // i18n
  language         String    @default("pt")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id])
  workspaceId         String
  team                Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId              String?
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  inviteToken         InviteToken?

  assignedLeads         Lead[]              @relation("AssignedLeads")
  assignedContacts      Contact[]           @relation("AssignedContacts")
  createdLeads          Lead[]              @relation("CreatedLeads")
  tasks                 Task[]
  messages              Message[]
  notes                 Note[]
  activities            Activity[]
  notifications         Notification[]
  chatbotFlows          ChatbotFlow[]
  automations           Automation[]
  pipelines             Pipeline[]
  broadcasts            Broadcast[]
  goals                 Goal[]
  assignedConversations ConversationMeta[]
  csatRequests          CsatRequest[]
  quotes                Quote[]
  aiSuggestionsDecided  AiSalesSuggestion[] @relation("AiSuggestionDecidedBy")
  appointments          Appointment[]       @relation("appointmentAssignedTo")

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

model Workspace {
  id                            String    @id @default(cuid())
  name                          String
  slug                          String    @unique
  logo                          String?
  timezone                      String    @default("Africa/Maputo")
  currency                      String    @default("MZN")
  // Terminologia customizavel do workspace (Fase 3 da reconfiguracao).
  // Permite que uma clinica veja "Pacientes", uma ONG veja "Formandos", uma
  // empresa comercial veja "Clientes". A entidade tecnica continua a chamar-se
  // Contact no schema — so a label visivel muda.
  contactLabelSingular          String    @default("Contacto")
  contactLabelPlural            String    @default("Contactos")
  // Terminologia customizavel para Marcacoes (Fase 3.4: clinicas usam "Consulta").
  appointmentLabelSingular      String    @default("Marcação")
  appointmentLabelPlural        String    @default("Marcações")
  // Tipos de consulta/marcacao configuraveis. Array de
  // { key, label, defaultDurationMin }. Ex: [{key:'primeira',label:'Primeira consulta',defaultDurationMin:45}]
  // Vazio = sem dropdown de tipo (usa so texto livre no titulo).
  appointmentTypes              Json      @default("[]")
  // Subscrição/plano: STARTER | GROWTH | BUSINESS | ENTERPRISE
  plan                          String    @default("STARTER")
  trialEndsAt                   DateTime?
  primaryColor                  String    @default("#6366F1")
  dateFormat                    String    @default("DD/MM/YYYY")
  fiscalYearStartMonth          Int       @default(1) // 1 = Janeiro
  autoAssignEnabled             Boolean   @default(false) // atribuicao round-robin de conversas novas
  // Opcoes customizaveis para tarefas (arrays JSON; vazio = usar defaults)
  // Formato cada item: { value: string, label: string, color?: string }
  taskTypes                     Json      @default("[]")
  taskPriorities                Json      @default("[]")
  taskStatuses                  Json      @default("[]")
  taskRecurrences               Json      @default("[]")
  // Títulos pré-definidos para tarefa (ex: Slide, Sinopse, Projecto, Monografia)
  taskTitles                    Json      @default("[]")
  // Labels customizadas dos campos do modal de tarefa.
  // Formato: { title: string, description: string, type: string, priority: string, dueAt: string, assignee: string, contact: string }
  taskFieldLabels               Json      @default("{}")
  // Digest diário de tarefas via WhatsApp para os responsáveis
  dailyDigestEnabled            Boolean   @default(false)
  dailyDigestHour               Int       @default(7) // 0-23 (hora local Africa/Maputo)
  dailyDigestMinute             Int       @default(0) // 0-59
  // Timestamp da última execução para evitar duplicar no mesmo minuto
  dailyDigestLastRunAt          DateTime?
  // Template customizável da mensagem do digest. Estrutura:
  // { header, overdueHeader, todayHeader, tomorrowHeader, taskLine, footer }
  // Vazio = usa defaults definidos no código.
  dailyDigestTemplate           Json      @default("{}")
  // Dias da semana em que o digest é enviado. Array de ints 0-6 (0=Dom,1=Seg,...,6=Sáb).
  // Default: todos os dias.
  dailyDigestWeekdays           Json      @default("[0,1,2,3,4,5,6]")
  assignmentNotifyEnabled       Boolean   @default(true)
  // Voz/tom da marca que a IA usa ao redigir mensagens (suggest-reply, agent-reply, improve-text)
  aiBrandVoice                  String?
  // Sector/ramo de actividade do workspace, usado pela IA Vendedora para escolher
  // tacticas e vocabulario adequados. Chaves alinhadas com sectorTemplates:
  // imobiliaria | clinica | escola | consultoria | outro.
  sector                        String    @default("outro")
  // Persona da IA Vendedora (configuravel por cliente do Klaru).
  aiAgentName                   String?
  aiAgentRole                   String?
  // Instrucoes livres do utilizador (ex: "Sempre sugere visita guiada antes
  // de proposta"). Concatenadas ao system prompt da IA Vendedora.
  aiAgentInstructions           String?
  // Memoria consolidada pelo job nocturno a partir das correccoes humanas
  // e dos fechos de leads (preenchida pela Fase 4 do plano).
  aiLearnedMemory               String?
  // === Fase 3 da IA Vendedora: execucao supervisionada ===
  // Liga/desliga a geracao automatica de sugestoes quando chega mensagem.
  aiSalesEnabled                Boolean   @default(false)
  // Modo de operacao da IA Vendedora:
  //   supervised  -> sugere, humano aprova/edita/descarta antes de enviar
  //   auto        -> envia directamente sem aprovacao humana (para a Fase 4)
  aiSalesMode                   String    @default("supervised")
  // Quais conversas (chave: contactId) tem IA Vendedora ligada quando o modo
  // global esta desligado. Array de strings. Decisao por conversa, conforme
  // a escolha feita na Fase 2.
  aiSalesEnabledConversationIds Json      @default("[]")
  // Limite duro de mensagens fragmentadas por resposta da IA. Conforme decisao
  // da Fase 2, default 4.
  aiSalesMaxParts               Int       @default(4)
  // Lista de palavras-trigger para handoff automatico (ex: "queixa", "reembolso").
  // Array de strings, lowercase, comparadas em substring contra a mensagem
  // recebida.
  aiSalesHandoffTriggers        Json      @default("[]")
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  users                User[]
  pipelines            Pipeline[]
  broadcasts           Broadcast[]
  contacts             Contact[]
  leads                Lead[]
  tags                 Tag[]
  integrations         Integration[]
  automations          Automation[]
  chatbotFlows         ChatbotFlow[]
  templates            MessageTemplate[]
  customFields         CustomField[]
  webhooks             Webhook[]
  goals                Goal[]
  conversationMetas    ConversationMeta[]
  teams                Team[]
  auditLogs            AuditLog[]
  systemEmailTemplates SystemEmailTemplate[]
  products             Product[]
  quotes               Quote[]
  aiSalesSuggestions   AiSalesSuggestion[]
  aiCoachingRules      AiCoachingRule[]
  aiCoachConversations AiCoachConversation[]
  aiUsageLogs          AiUsageLog[]
  appointments         Appointment[]

  // === Tracking de consumo de tokens LLM ===
  // Cache do uso actual para evitar somar a tabela em cada chamada.
  // Sao recalculados periodicamente a partir de AiUsageLog.
  aiTokensUsedToday    Int       @default(0)
  aiTokensUsedMonth    Int       @default(0)
  aiTokensUsageDay     DateTime? // data do contador diario (YYYY-MM-DD UTC)
  aiTokensUsageMonth   String?   // "YYYY-MM" do contador mensal
  // Override por workspace (null = usar o limite do plano)
  aiTokensDailyLimitOverride   Int?
  aiTokensMonthlyLimitOverride Int?

  // === Auto-tarefa: envio de mensagem com criacao/actualizacao automatica ===
  // Configuravel pelo admin em Definicoes > Auto-tarefa. Estrutura JSON:
  //   {
  //     workTypes: [
  //       { key, label, article: 'a'|'o'|'os', possessive: 'tua'|'teu'|'tuas' },
  //       ...
  //     ],
  //     announceTemplate: string,  // com {nome} {assunto} {tipo} {artigo} {possessivo} {data}
  //     deliverTemplate: string,
  //     followupTitleTemplate: string,
  //     announceTaskTitleTemplate: string,
  //     followupDays: number
  //   }
  // Null = usa os defaults hardcoded em lib/autoTaskDefaults.ts
  autoTaskConfig Json?

  @@map("workspaces")
}

// ==================== PIPELINE & LEADS ====================

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3B82F6")
  isDefault   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  stages Stage[]
  leads  Lead[]

  @@map("pipelines")
}

model Stage {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#6B7280")
  position  Int
  type      StageType @default(REGULAR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String

  leads Lead[]

  @@map("stages")
}

enum StageType {
  REGULAR
  WON
  LOST
}

model Lead {
  id              String     @id @default(cuid())
  title           String
  value           Float?
  currency        String     @default("MZN")
  status          LeadStatus @default(OPEN)
  priority        Priority   @default(MEDIUM)
  source          String?
  lostReason      String?
  expectedCloseAt DateTime?
  closedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId  String
  pipeline     Pipeline  @relation(fields: [pipelineId], references: [id])
  pipelineId   String
  stage        Stage     @relation(fields: [stageId], references: [id])
  stageId      String
  assignedTo   User?     @relation("AssignedLeads", fields: [assignedToId], references: [id])
  assignedToId String?
  createdBy    User      @relation("CreatedLeads", fields: [createdById], references: [id])
  createdById  String
  contact      Contact?  @relation(fields: [contactId], references: [id])
  contactId    String?

  tasks              Task[]
  messages           Message[]
  notes              Note[]
  activities         Activity[]
  tags               TagOnLead[]
  customValues       CustomFieldValue[]
  files              File[]
  csatRequests       CsatRequest[]
  quotes             Quote[]
  aiSalesSuggestions AiSalesSuggestion[]
  appointments       Appointment[]

  @@map("leads")
}

enum LeadStatus {
  OPEN
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==================== CONTACTS ====================

model Contact {
  id          String      @id @default(cuid())
  type        ContactType @default(PERSON)
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  whatsapp    String?
  instagramId String? // IGSID (Instagram Scoped ID)
  facebookId  String? // PSID (Page-Scoped ID) Messenger
  tiktokId    String?
  company     String?
  position    String?
  website     String?
  avatar      String?
  address     String?
  city        String?
  country     String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  assignedTo   User?   @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?

  leads               Lead[]
  broadcastRecipients BroadcastRecipient[]
  messages            Message[]
  tags                TagOnContact[]
  customValues        CustomFieldValue[]
  conversationMetas   ConversationMeta[]
  csatRequests        CsatRequest[]
  tasks               Task[]
  quotes              Quote[]
  aiSalesSuggestions  AiSalesSuggestion[]
  appointments        Appointment[]

  @@index([assignedToId])
  @@map("contacts")
}

enum ContactType {
  PERSON
  COMPANY
}

// ==================== MESSAGING ====================

model Message {
  id            String        @id @default(cuid())
  content       String
  type          MessageType   @default(TEXT)
  direction     Direction     @default(OUTBOUND)
  channel       Channel
  status        MessageStatus @default(SENT)
  mediaUrl      String?
  mediaType     String?
  externalId    String?
  readAt        DateTime?
  editedAt      DateTime?
  isInternal    Boolean       @default(false)
  transcription String? // transcricao de audio via Groq Whisper (preenchida on-demand)
  createdAt     DateTime      @default(now())

  lead      Lead?    @relation(fields: [leadId], references: [id])
  leadId    String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
  sentBy    User?    @relation(fields: [sentById], references: [id])
  sentById  String?

  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  aiSalesSuggestionsTriggered AiSalesSuggestion[] @relation("AiSuggestionTriggerMessage")

  // Indices essenciais para acelerar GET /messages (lista por contacto/lead)
  // e GET /messages/conversations (top recentes do workspace).
  @@index([contactId, createdAt])
  @@index([leadId, createdAt])
  @@index([createdAt])
  @@index([externalId])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  TEMPLATE
  INTERACTIVE
  SYSTEM
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum Channel {
  WHATSAPP
  EMAIL
  INSTAGRAM
  FACEBOOK
  TELEGRAM
  WEBCHAT
  SMS
  INTERNAL
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ==================== TASKS ====================

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  // Customizáveis no Workspace (taskTypes/taskStatuses/taskPriorities).
  // Mantidos como String para aceitar valores definidos pelo utilizador.
  type        String    @default("CALL")
  status      String    @default("PENDING")
  priority    String    @default("MEDIUM")
  dueAt       DateTime?
  completedAt DateTime?
  recurrence  String? // DAILY | WEEKLY | MONTHLY (null = nao recorrente)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead         Lead?    @relation(fields: [leadId], references: [id])
  leadId       String?
  contact      Contact? @relation(fields: [contactId], references: [id])
  contactId    String?
  assignedTo   User     @relation(fields: [assignedToId], references: [id])
  assignedToId String

  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]  @relation("Subtasks")

  tags TagOnTask[]

  @@index([contactId])
  @@map("tasks")
}

// ==================== NOTES ====================

model Note {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead        Lead?   @relation(fields: [leadId], references: [id])
  leadId      String?
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  @@map("notes")
}

// ==================== ACTIVITY LOG ====================

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  lead   Lead?   @relation(fields: [leadId], references: [id])
  leadId String?
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@map("activities")
}

enum ActivityType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_MOVED
  LEAD_WON
  LEAD_LOST
  MESSAGE_SENT
  MESSAGE_RECEIVED
  TASK_CREATED
  TASK_COMPLETED
  NOTE_ADDED
  FILE_UPLOADED
  CONTACT_LINKED
  TAG_ADDED
  TAG_REMOVED
  ASSIGNED
  STAGE_CHANGED
  VALUE_CHANGED
}

// ==================== AUTOMATION ====================

model Automation {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  isActive           Boolean   @default(true)
  trigger            Json // { type, params } incluindo schedule (every_X_minutes/daily_at/weekly_at), no_response, lead_stagnant
  conditions         Json? // { op: "AND"|"OR", items: [{field, op, value}] }   ou array legado [{...}]
  actions            Json // [{ type, params, delaySeconds? }]
  runCount           Int       @default(0)
  lastRunAt          DateTime?
  // Horario activo (opcional)
  activeHoursStart   Int? // 0-23
  activeHoursEnd     Int? // 0-23
  activeWeekdays     String? // "1234567" (1=Segunda...7=Domingo)
  // Limites
  runLimitPerContact Int? // max execucoes por contacto
  runLimitTotal      Int? // max execucoes total
  runLimitWindow     Int? // janela em horas
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  runs AutomationRun[]

  @@map("automations")
}

// Historico de execucoes (uma entrada por disparo de regra)
model AutomationRun {
  id           String     @id @default(cuid())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  automationId String
  workspaceId  String
  triggeredBy  String // tipo de evento que disparou
  entityType   String? // "lead" | "task" | "message" | etc
  entityId     String?
  contactId    String? // para verificar limite por contacto
  leadId       String? // para activity log integrado
  status       String     @default("OK") // OK | SKIPPED | FAILED
  log          Json       @default("[]") // [{at, action, detail}]
  createdAt    DateTime   @default(now())

  @@index([automationId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([contactId, automationId])
  @@index([leadId])
  @@map("automation_runs")
}

// ==================== CHATBOT ====================

model ChatbotFlow {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  isActive              Boolean  @default(true)
  trigger               String // "first_message" | "keyword" | "always"
  triggerValue          String? // palavra-chave (quando trigger = "keyword")
  channel               String   @default("WHATSAPP") // WHATSAPP | EMAIL | etc
  nodes                 Json
  edges                 Json
  runCount              Int      @default(0)
  leadCount             Int      @default(0)
  // Horario comercial (opcional)
  businessHoursStart    Int? // 0-23
  businessHoursEnd      Int? // 0-23
  businessHoursWeekdays String? // "1234567"
  outOfHoursMessage     String?
  language              String   @default("pt") // pt | en | etc
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  sessions ChatbotSession[]

  @@map("chatbot_flows")
}

// Sessao de execucao por contacto: guarda em que no o fluxo esta parado a espera de resposta
model ChatbotSession {
  id            String      @id @default(cuid())
  flow          ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId        String
  workspaceId   String
  contactId     String
  leadId        String?
  currentNodeId String // no onde a execucao esta parada (geralmente um no que espera resposta)
  variables     Json        @default("{}") // valores capturados pelas perguntas durante o fluxo
  log           Json        @default("[]") // historico de passos executados [{at, nodeId, nodeType, action, detail}]
  isFinished    Boolean     @default(false)
  resumeAt      DateTime? // para nos de "esperar tempo"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workspaceId, contactId])
  @@index([resumeAt])
  @@map("chatbot_sessions")
}

// ==================== TEMPLATES ====================

model MessageTemplate {
  id         String           @id @default(cuid())
  name       String
  content    String
  category   TemplateCategory
  channel    Channel
  variables  String[]         @default([])
  isApproved Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  @@map("message_templates")
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

// ==================== TAGS ====================

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  leads         TagOnLead[]
  contacts      TagOnContact[]
  tasks         TagOnTask[]
  conversations TagOnConversation[]

  @@unique([name, workspaceId])
  @@map("tags")
}

model TagOnLead {
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([leadId, tagId])
  @@map("tags_on_leads")
}

model TagOnContact {
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([contactId, tagId])
  @@map("tags_on_contacts")
}

model TagOnTask {
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([taskId, tagId])
  @@map("tags_on_tasks")
}

// ==================== CUSTOM FIELDS ====================

model CustomField {
  id         String          @id @default(cuid())
  name       String
  key        String
  type       CustomFieldType
  entity     String
  options    String[]        @default([])
  isRequired Boolean         @default(false)
  position   Int             @default(0)
  createdAt  DateTime        @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  values CustomFieldValue[]

  @@unique([key, workspaceId, entity])
  @@map("custom_fields")
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  URL
  EMAIL
  PHONE
}

model CustomFieldValue {
  id    String @id @default(cuid())
  value String

  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId   String
  lead      Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String?
  contact   Contact?    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String?

  @@map("custom_field_values")
}

